{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "module": "node16",
    "moduleResolution": "node16",
    "target": "es2022",
    "lib": ["es2023", "dom"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false
  },
  "include": [
    "*.js",
    "scripts/**/*.js",
    "tests/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "design-system",
    "playwright-report",
    "test-results",
    "day*-*.mjs"
  ]
}
