# Halastudy environment configuration
# Copy to `.env` (or set these in ecosystem.config.js / your process manager).
# Most vars have development defaults, but production behind Nginx must set
# PORT, TRUST_PROXY, ALLOWED_ORIGINS, ROOM_STATE_* paths, ICE_SERVERS_JSON
# (TURN), and RealtimeKit credentials when VIDEO_PROVIDER=realtimekit.

# --- Network -----------------------------------------------------------------

# HTTP listen port for server.js. Default: 3000.
PORT=3000

# Runtime mode. In production, missing required RealtimeKit credentials fail
# startup when VIDEO_PROVIDER=realtimekit.
NODE_ENV=development

# HTTPS listen port for server-https.js (local secure-context testing only;
# production terminates TLS at Nginx and runs plain server.js). Default: 3443.
# HTTPS_PORT=3443

# Set to 1 when running behind a trusted reverse proxy (Nginx) so Express reads
# X-Forwarded-Proto/For — REQUIRED in production for Secure cookies and correct
# per-client rate limiting. "0" or "1" only. Default: 0.
TRUST_PROXY=1

# Comma-separated list of bare origins allowed to embed/connect (Socket.IO CORS
# + HTTP origin guard). Set this explicitly in production — do not rely on the
# empty-list same-origin fallback. Example:
ALLOWED_ORIGINS=https://your-domain.com

# --- Persistence -------------------------------------------------------------
# Point these OUTSIDE the repo/deploy directory in production, so a re-clone or
# `git clean` during a future deploy can never destroy live room state.
# Defaults are repo-relative (data/rooms.json, data/users.json, data/backups).
ROOM_STATE_FILE=/var/lib/halastudy/rooms.json
USER_STATE_FILE=/var/lib/halastudy/users.json
ROOM_STATE_BACKUP_DIR=/var/lib/halastudy/backups

# Automated backups of rooms + users state. 0 disables the scheduler; minimum
# interval is 5 minutes. Retention is per label (rooms / users).
BACKUP_INTERVAL_MINUTES=60
BACKUP_RETENTION_COUNT=48

# --- Accounts & sessions -------------------------------------------------------
# HMAC key for signed auth cookies (user + admin). Min 32 chars. REQUIRED in
# production — startup fails without it. Rotating it signs everyone out.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_me_with_32_plus_random_chars

# --- Admin portal (hidden ops console) ----------------------------------------
# BOTH must be set for the portal to exist; otherwise every admin path 404s
# exactly like any unknown URL. Keep ADMIN_PATH unguessable and rotate it if it
# leaks (browser history, proxy logs). The password is the real gate.
# Generate the hash with: npm run admin:hash -- "your-admin-password"
# ADMIN_PATH=/ops-replace-me
# ADMIN_PASSWORD_HASH=

# --- Media -------------------------------------------------------------------

# Max participants per mesh (P2P) room. Default: 4. Drop to 3 if mid-range
# phones thermally throttle on 3 simultaneous encodes (no code change needed).
MESH_PARTICIPANT_LIMIT=4

# Absolute http(s) base URL of the legacy iframe SFU. Leave unset for the
# RealtimeKit launch unless intentionally testing VIDEO_PROVIDER=mesh fallback.
# No query/fragment.
# SFU_BASE_URL=

# ICE servers as a JSON array, delivered to browsers via /api/runtime-config.
# Defaults to Google public STUN only, which FAILS across strict/CGNAT NATs
# (common on Saudi mobile carriers) — set a TURN relay for production. Include a
# turns:...:443?transport=tcp entry so calls survive restrictive firewalls.
# Example (managed TURN — replace host/credentials with your provider's):
# ICE_SERVERS_JSON=[{"urls":["stun:stun.relay.example.com:80"]},{"urls":["turn:relay.example.com:80","turn:relay.example.com:443?transport=tcp","turns:relay.example.com:443?transport=tcp"],"username":"REPLACE_ME","credential":"REPLACE_ME"}]

# --- Video provider ----------------------------------------------------------

# Default launch provider. Use "mesh" only as an emergency fallback while the
# legacy P2P path remains in the app.
VIDEO_PROVIDER=realtimekit
VIDEO_JOIN_DISABLED=false
MAX_GLOBAL_VIDEO_PARTICIPANTS=20
MAX_ROOM_VIDEO_PARTICIPANTS=20
MAX_ROOM_DURATION_MINUTES=180
VIDEO_RECORDING_ENABLED=false
VIDEO_SCREENSHARE_ENABLED=false
VIDEO_CHAT_ENABLED=false
VIDEO_DEFAULT_PRESET_NAME=halastudy_student
# Watch-only preset for Lobby guests (produce/publish disabled). Provision this
# second preset in Cloudflare (scripts/cloudflare/realtimekit-setup.js) before
# the Lobby goes live; falls back to the student preset if absent.
VIDEO_VIEWER_PRESET_NAME=halastudy_viewer

# Cloudflare RealtimeKit - SERVER ONLY. Never expose these values to frontend JS.
CLOUDFLARE_ACCOUNT_ID=replace_me
CLOUDFLARE_REALTIMEKIT_APP_ID=replace_me
CLOUDFLARE_REALTIMEKIT_API_TOKEN=replace_me

# Public API URL for a future Cloudflare Pages frontend.
PUBLIC_API_BASE_URL=http://localhost:3000

# --- Cloudflare R2 (off-site state backups) ----------------------------------
# Optional. When set, `npm run backup:r2` uploads the rooms + users snapshots to
# an R2 bucket so state survives VM loss. Create an R2 API token (S3-compatible)
# in the Cloudflare dashboard; it gives you the Access Key ID + Secret Access Key
# and an account-scoped endpoint. SERVER-ONLY secrets — never expose to frontend.
R2_ACCOUNT_ID=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=halastudy-backups
# Optional: the Bearer API token (cfat_...) for REST bucket management. The S3
# data operations (upload/download) use the Access Key pair above, not this.
R2_API_TOKEN=

# --- Supabase (accounts + dashboards) ----------------------------------------
# Project "halastudy" (ref bnjkrxiahbdlmezusnjc, region ap-south-1) in the
# azizme.com org. The URL is public; fill the keys from the dashboard
# (Project Settings → API). SERVICE_ROLE is a secret — server-only, never
# ship to the browser. Not wired into the app yet (integration is the next
# phase); the schema + dashboard views already live in the project.
SUPABASE_URL=https://bnjkrxiahbdlmezusnjc.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# When SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are both set, accounts persist
# to the Supabase `profiles` table (and focus/room analytics feed the admin
# dashboard views). Unset → the app falls back to the local users.json store.

# --- Google Sign-In (OAuth 2.0) ----------------------------------------------
# When CLIENT_ID + CLIENT_SECRET are both set, a "Continue with Google" button
# appears on /account and the /auth/google routes activate; unset → they 404.
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console →
# APIs & Services → Credentials. Authorized redirect URI must EXACTLY match
# GOOGLE_REDIRECT_URI below (defaults to <first ALLOWED_ORIGINS>/auth/google/callback).
# SERVER-ONLY secret — never expose the client secret to the browser.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override; defaults to https://<your-domain>/auth/google/callback
# GOOGLE_REDIRECT_URI=https://halastudy.com/auth/google/callback
