# Halastudy environment configuration
# Copy to `.env` (or set these in ecosystem.config.js / your process manager).
# Every var is optional — the app boots on defaults — but production behind
# Nginx should set at least PORT, TRUST_PROXY, ALLOWED_ORIGINS, the two
# ROOM_STATE_* paths, and ICE_SERVERS_JSON (TURN). Parsed in
# resolveServerConfig() — co-study-server.js:284.

# --- Network -----------------------------------------------------------------

# HTTP listen port for server.js. Default: 3000.
PORT=3000

# HTTPS listen port for server-https.js (local secure-context testing only;
# production terminates TLS at Nginx and runs plain server.js). Default: 3443.
# HTTPS_PORT=3443

# Set to 1 when running behind a trusted reverse proxy (Nginx) so Express reads
# X-Forwarded-Proto/For — REQUIRED in production for Secure cookies and correct
# per-client rate limiting. "0" or "1" only. Default: 0.
TRUST_PROXY=1

# Comma-separated list of bare origins allowed to embed/connect (Socket.IO CORS
# + HTTP origin guard). Set this explicitly in production — do not rely on the
# empty-list same-origin fallback. Example:
ALLOWED_ORIGINS=https://your-domain.com

# --- Persistence -------------------------------------------------------------
# Point these OUTSIDE the repo/deploy directory in production, so a re-clone or
# `git clean` during a future deploy can never destroy live room state.
# Defaults are repo-relative (data/rooms.json, data/backups).
ROOM_STATE_FILE=/var/lib/halastudy/rooms.json
ROOM_STATE_BACKUP_DIR=/var/lib/halastudy/backups

# --- Media -------------------------------------------------------------------

# Max participants per mesh (P2P) room. Default: 4. Drop to 3 if mid-range
# phones thermally throttle on 3 simultaneous encodes (no code change needed).
MESH_PARTICIPANT_LIMIT=4

# Absolute http(s) base URL of a MiroTalk SFU for large rooms. LEAVE UNSET for
# the mesh-only v1 launch — unset disables SFU mode entirely. No query/fragment.
# SFU_BASE_URL=

# ICE servers as a JSON array, delivered to browsers via /api/runtime-config.
# Defaults to Google public STUN only, which FAILS across strict/CGNAT NATs
# (common on Saudi mobile carriers) — set a TURN relay for production. Include a
# turns:...:443?transport=tcp entry so calls survive restrictive firewalls.
# Example (managed TURN — replace host/credentials with your provider's):
# ICE_SERVERS_JSON=[{"urls":["stun:stun.relay.example.com:80"]},{"urls":["turn:relay.example.com:80","turn:relay.example.com:443?transport=tcp","turns:relay.example.com:443?transport=tcp"],"username":"REPLACE_ME","credential":"REPLACE_ME"}]
